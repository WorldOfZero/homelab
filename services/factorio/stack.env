#version=1.1
#URL=https://github.com/tailscale-dev/ScaleTail
COMPOSE_PROJECT_NAME=factorio
# Service Configuration
SERVICE=factorio

SERVICEPORT=34197
DNS_SERVER=9.9.9.9

# Tailscale Configuration
# TS_AUTHKEY= - This is generated elsewhere

# Optional Service variables
# PUID=1000

#Time Zone setting for containers 
TZ=America/Los_Angeles # See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

# Any Container environment variables are declared below. See https://docs.docker.com/compose/how-tos/environment-variables/

PRESET=rail-world
INSTANCE_NAME="World of Zero"
INSTANCE_DESCRIPTION="Multiplayer rail world."